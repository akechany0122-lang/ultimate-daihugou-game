+      z-index: 1002;
+      transition: all 0.3s ease;
+      text-align: center;
+      margin-top: 15px; /* ロゴの下部に配置 */
+      user-select: none;
+      animation: touch-pulse 2s infinite ease-in-out;
+    }
+    .touch-start-container:hover {
+      filter: brightness(1.25);
